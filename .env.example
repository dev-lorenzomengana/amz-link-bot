# File di configurazione per il bot Telegram Amazon Affiliate Personalizzato
# Copia questo file in .env e compila con i tuoi dati

# Token del bot Telegram (ottieni da @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ID amministratori del bot per statistiche globali (separati da virgole)
ADMIN_IDS=123456789,987654321

# IMPORTANTE: Tag affiliato Amazon non più necessario qui!
# Ogni utente configura il proprio tag con /settag nel bot

# Per ottenere il tuo ID Telegram per ADMIN_IDS:
# 1. Invia messaggio a @userinfobot
# 2. Copia l'ID che ti risponde

# ============================================================
# OPZIONALE — Product Advertising API (PA-API) di Amazon
# ============================================================
# Serve SOLO se vuoi mostrare titolo/prezzo/immagine del prodotto nelle risposte.
# Lascia vuoto se non hai le chiavi: il bot funziona comunque (converte i link).
# Richiede: account Amazon Associates approvato + `pip install amazon-paapi`
PAAPI_ACCESS_KEY=
PAAPI_SECRET_KEY=
PAAPI_PARTNER_TAG=
# Paese di default se non deducibile dal dominio del link (es. US, IT, DE, UK...)
PAAPI_COUNTRY=IT